# Application name — shown in navbar, login page, browser tab
NEXT_PUBLIC_APP_NAME=StreamVault

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/streamvault

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-string-min-32-chars

# First admin account (auto-created on first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password-min-8-chars

# Comma-separated index page URLs to crawl for videos
CRAWL_URLS=https://www.rfmri.org/Course/V3.0EN/,https://www.rfmri.org/Course/V2.0EN/
